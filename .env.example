# ============================================
# Voice Assistant - Environment Template
# ============================================

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
API_KEY=your-internal-api-key

# Database (SQLite)
DATABASE_URL="file:./dev.db"

# Redis (for campaign queue)
REDIS_URL=redis://localhost:6379

# Twilio (Optional - for real calls)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WEBHOOK_BASE_URL=https://your-domain.ngrok.app

# Deepgram (Optional - for voice pipeline)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Google Cloud TTS (Optional)
# GOOGLE_APPLICATION_CREDENTIALS path should be relative to root
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
GOOGLE_TTS_VOICE_NAME=en-IN-Neural2-A
GOOGLE_TTS_LANGUAGE_CODE=en-IN

# Groq (Primary AI Engine)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-8b-8192

# Voice Pipeline Settings
STT_CONFIDENCE_THRESHOLD=0.5
MAX_LOW_CONFIDENCE_COUNT=3
AI_RESPONSE_TIMEOUT_MS=2500
MAX_CALL_RETRY_COUNT=2
RETRY_DELAY_MINUTES=30
INTER_CALL_DELAY_MS=2000

# Calling Hours (24h format)
CALLING_HOURS_START=09:00
CALLING_HOURS_END=20:00
